---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
---

<header
  class:list={[
    "max-w-2xl",
    align === "center" ? "mx-auto text-center" : "text-left",
  ]}
>
  {
    eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-(--color-brand-600)">
        {eyebrow}
      </p>
    )
  }
  <h2
    class:list={[
      "font-bold tracking-tight text-balance text-(--color-ink-900)",
      "text-3xl leading-[1.15] sm:text-4xl sm:leading-[1.12]",
      eyebrow ? "mt-3" : "",
    ]}
  >
    {title}
  </h2>
  {
    description && (
      <p class="mt-5 max-w-2xl text-base leading-relaxed text-(--color-ink-600) sm:text-lg">
        {description}
      </p>
    )
  }
</header>
