---
import type { Lang } from "../data/company";
import { company } from "../data/company";
import { dict, pathFor } from "../i18n/dict";

interface Props {
  lang: Lang;
  currentPath?: string;
}

const { lang, currentPath = "/" } = Astro.props;

const navItems = [
  { key: "about", slug: "/about" },
  { key: "services", slug: "/services" },
  { key: "research", slug: "/research" },
  { key: "news", slug: "/news" },
  { key: "contact", slug: "/contact" },
] as const;

const otherLang: Lang = lang === "ko" ? "en" : "ko";
const langTogglePath = (() => {
  const stripped = currentPath.replace(/^\/en/, "") || "/";
  return otherLang === "en"
    ? `/en${stripped === "/" ? "" : stripped}`
    : stripped;
})();
---

<header
  class="sticky top-0 z-40 w-full border-b border-(--color-ink-100)/80 bg-white/85 backdrop-blur-md supports-[backdrop-filter]:bg-white/70"
>
  <div
    class="container-page flex h-16 items-center justify-between gap-8 sm:h-20"
  >
    <a
      href={pathFor("/", lang)}
      class="flex items-center"
      aria-label={company.shortName[lang]}
    >
      <img
        src="/img/logo/wordmark-symbol-blue-ko-trimmed.png"
        alt={company.shortName.ko}
        class="h-14 w-auto sm:h-16"
      />
    </a>

    <nav
      class="hidden items-center gap-1 md:flex"
      aria-label={lang === "ko" ? "주메뉴" : "Primary"}
    >
      {
        navItems.map((item) => {
          const href = pathFor(item.slug, lang);
          const isActive =
            currentPath === href || currentPath.startsWith(href.replace(/\/$/, "") + "/");
          return (
            <a
              href={href}
              class:list={[
                "relative rounded-md px-3 py-2 text-sm font-medium transition-colors",
                isActive
                  ? "text-(--color-brand-600)"
                  : "text-(--color-ink-700) hover:bg-(--color-ink-50) hover:text-(--color-ink-900)",
              ]}
              aria-current={isActive ? "page" : undefined}
            >
              {dict.nav[item.key][lang]}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={langTogglePath}
        class="rounded-md border border-(--color-ink-200) px-3 py-1.5 text-xs font-semibold tracking-wider text-(--color-ink-700) transition hover:border-(--color-ink-400) hover:text-(--color-ink-900)"
        hreflang={otherLang}
        aria-label={otherLang === "en" ? "Switch to English" : "한국어로 전환"}
      >
        {dict.langToggle[lang]}
      </a>

      <button
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-(--color-ink-200) text-(--color-ink-700) md:hidden"
        aria-label={lang === "ko" ? "메뉴 열기" : "Open menu"}
        data-mobile-nav-toggle
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-5 w-5"
          aria-hidden="true"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <div
    class="border-t border-(--color-ink-100) md:!hidden"
    data-mobile-nav
    hidden
  >
    <nav class="container-page flex flex-col py-4">
      {
        navItems.map((item) => (
          <a
            href={pathFor(item.slug, lang)}
            class="py-3 text-base font-medium text-(--color-ink-800) hover:text-(--color-brand-600)"
          >
            {dict.nav[item.key][lang]}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(
    "[data-mobile-nav-toggle]",
  );
  const panel = document.querySelector<HTMLElement>("[data-mobile-nav]");
  if (toggle && panel) {
    toggle.setAttribute("aria-expanded", "false");
    toggle.setAttribute("aria-controls", "mobile-nav-panel");
    panel.id = "mobile-nav-panel";
    toggle.addEventListener("click", () => {
      const open = panel.hasAttribute("hidden");
      if (open) {
        panel.removeAttribute("hidden");
        toggle.setAttribute("aria-expanded", "true");
      } else {
        panel.setAttribute("hidden", "");
        toggle.setAttribute("aria-expanded", "false");
      }
    });
  }
</script>
