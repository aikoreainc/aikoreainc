---
import type { Lang } from "../data/company";
import type { Paper } from "../data/research";
import { doiUrl } from "../data/research";

interface Props {
  paper: Paper;
  lang: Lang;
}

const { paper, lang } = Astro.props;
const readDoi = lang === "ko" ? "DOI로 이동" : "View on DOI";
---

<article
  class="lift-on-hover flex h-full flex-col rounded-2xl border border-(--color-ink-200) bg-white p-7 hover:border-(--color-brand-400) sm:p-8"
>
  <div class="flex flex-wrap items-center gap-2">
    <span
      class="rounded-full bg-(--color-brand-50) px-2.5 py-1 text-xs font-semibold tracking-[0.08em] text-(--color-brand-700)"
    >
      {paper.year}
    </span>
    {
      paper.topics.map((topic) => (
        <span class="rounded-full bg-(--color-ink-100) px-2.5 py-1 text-xs font-medium text-(--color-ink-600)">
          {topic}
        </span>
      ))
    }
  </div>
  <h3
    class="mt-4 text-lg font-bold leading-snug text-(--color-ink-900) sm:text-xl"
  >
    {paper.title}
  </h3>
  <p class="mt-3 text-sm text-(--color-ink-600)">
    {paper.authors} ·
    <em class="not-italic text-(--color-ink-700)">{paper.journal}</em>
     · {paper.volume}:{paper.page}
  </p>
  <p class="mt-4 text-sm leading-relaxed text-(--color-ink-700)">
    {paper.summary[lang]}
  </p>
  <a
    href={doiUrl(paper.doi)}
    target="_blank"
    rel="noopener"
    class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-(--color-brand-600) hover:text-(--color-brand-700)"
  >
    {readDoi}
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="h-3.5 w-3.5"
      aria-hidden="true"
    >
      <path d="M7 17L17 7"></path>
      <polyline points="7 7 17 7 17 17"></polyline>
    </svg>
  </a>
</article>
