---
import type { Lang } from "../data/company";
import { partners } from "../data/partners";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const heading = lang === "ko" ? "협력 기관" : "Partners";
const sub =
  lang === "ko"
    ? "정부·연구·의료·산업 분야의 기관·기업과 협력하고 있습니다."
    : "We collaborate with public, research, medical, and industry partners.";
---

<section class="border-t border-(--color-ink-200) bg-white">
  <div class="container-page py-16 sm:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p
        class="text-xs font-semibold uppercase tracking-[0.12em] text-(--color-brand-600)"
      >
        {lang === "ko" ? "PARTNERS" : "PARTNERS"}
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-(--color-ink-900) sm:text-4xl">
        {heading}
      </h2>
      <p class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-(--color-ink-600) sm:text-lg">
        {sub}
      </p>
    </div>

    <ul
      class="mx-auto mt-12 grid grid-cols-2 gap-3 sm:mt-14 sm:grid-cols-4 sm:gap-4 sm:[&>li:nth-child(5)]:col-start-2"
    >
      {
        partners.map((p) => {
          const Tag = p.url ? "a" : "div";
          const props = p.url
            ? { href: p.url, target: "_blank", rel: "noopener" }
            : {};
          return (
            <li>
              <Tag
                {...props}
                class="flex h-20 w-full items-center justify-center rounded-xl border border-(--color-ink-200) bg-(--color-ink-50) px-5 text-sm font-semibold text-(--color-ink-700) transition duration-200 hover:border-(--color-brand-400) hover:bg-white hover:text-(--color-brand-700) sm:h-24 sm:text-base"
              >
                {p.logo ? (
                  <img
                    src={p.logo}
                    alt={p.name[lang]}
                    loading="lazy"
                    class="max-h-10 w-auto opacity-90 transition-opacity hover:opacity-100 sm:max-h-12"
                  />
                ) : (
                  <span class="text-center leading-tight">{p.name[lang]}</span>
                )}
              </Tag>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>
