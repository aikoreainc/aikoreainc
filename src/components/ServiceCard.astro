---
import type { Lang } from "../data/company";
import type { Service } from "../data/services";

interface Props {
  service: Service;
  lang: Lang;
}

const { service, lang } = Astro.props;
const products = service.products ?? [];
const isSingle = products.length === 1;
const isMulti = products.length > 1;
const visitSite = lang === "ko" ? "사이트 방문" : "Visit site";
const learnMore = lang === "ko" ? "문의로 자세히 보기" : "Ask for details";

const cardClass =
  "lift-on-hover group flex h-full flex-col rounded-2xl border border-(--color-ink-200) bg-white p-7 hover:-translate-y-0.5 hover:border-(--color-brand-400) sm:p-8";
---

{
  isSingle ? (
    <a
      href={products[0].url}
      target="_blank"
      rel="noopener"
      class={cardClass}
    >
      <div class="flex items-start justify-between gap-4">
        <h3 class="text-lg font-bold text-(--color-ink-900) group-hover:text-(--color-brand-700) sm:text-xl">
          {service.title[lang]}
        </h3>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4 shrink-0 text-(--color-ink-400) group-hover:text-(--color-brand-600)"
          aria-hidden="true"
        >
          <path d="M7 17L17 7" />
          <polyline points="7 7 17 7 17 17" />
        </svg>
      </div>
      <p class="mt-3 text-sm leading-relaxed text-(--color-ink-600) sm:text-base">
        {service.summary[lang]}
      </p>
      <ul class="mt-5 space-y-2">
        {service.highlights[lang].map((h) => (
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-(--color-ink-700)">
            <span
              class="mt-2 inline-block h-1 w-1 shrink-0 rounded-full bg-(--color-brand-500)"
              aria-hidden="true"
            />
            <span>{h}</span>
          </li>
        ))}
      </ul>
      <p class="mt-auto pt-6 text-sm font-semibold text-(--color-brand-600) group-hover:text-(--color-brand-700)">
        {visitSite} →
      </p>
    </a>
  ) : (
    <div class={cardClass}>
      <h3 class="text-lg font-bold text-(--color-ink-900) sm:text-xl">
        {service.title[lang]}
      </h3>
      <p class="mt-3 text-sm leading-relaxed text-(--color-ink-600) sm:text-base">
        {service.summary[lang]}
      </p>
      <ul class="mt-5 space-y-2">
        {service.highlights[lang].map((h) => (
          <li class="flex items-start gap-2.5 text-sm leading-relaxed text-(--color-ink-700)">
            <span
              class="mt-2 inline-block h-1 w-1 shrink-0 rounded-full bg-(--color-brand-500)"
              aria-hidden="true"
            />
            <span>{h}</span>
          </li>
        ))}
      </ul>
      {isMulti && (
        <div class="mt-auto flex flex-wrap gap-2 pt-6">
          {products.map((p) => (
            <a
              href={p.url}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 rounded-md border border-(--color-ink-200) bg-(--color-ink-50) px-3 py-1.5 text-xs font-semibold text-(--color-ink-800) transition hover:border-(--color-brand-400) hover:bg-white hover:text-(--color-brand-700)"
            >
              {p.name}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-3 w-3"
                aria-hidden="true"
              >
                <path d="M7 17L17 7" />
                <polyline points="7 7 17 7 17 17" />
              </svg>
            </a>
          ))}
        </div>
      )}
      {!isMulti && (
        <p class="mt-auto pt-6 text-sm font-semibold text-(--color-ink-500)">
          {learnMore} →
        </p>
      )}
    </div>
  )
}
