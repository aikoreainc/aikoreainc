---
import type { Lang } from "../data/company";
import type { Service } from "../data/services";

interface Props {
  service: Service;
  lang: Lang;
  href: string;
}

const { service, lang, href } = Astro.props;
const isExternal = Boolean(service.externalUrl);
const learnMore = lang === "ko" ? "자세히 보기" : "Learn more";
const visitSite = lang === "ko" ? "사이트 방문" : "Visit site";
---

<a
  href={href}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noopener" : undefined}
  class="group flex h-full flex-col rounded-2xl border border-(--color-ink-200) bg-white p-7 transition hover:border-(--color-brand-400) hover:shadow-sm sm:p-8"
>
  <div class="flex items-start justify-between gap-4">
    <h3
      class="text-lg font-bold text-(--color-ink-900) group-hover:text-(--color-brand-700) sm:text-xl"
    >
      {service.title[lang]}
    </h3>
    {
      isExternal && (
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4 shrink-0 text-(--color-ink-400) group-hover:text-(--color-brand-600)"
          aria-hidden="true"
        >
          <path d="M7 17L17 7" />
          <polyline points="7 7 17 7 17 17" />
        </svg>
      )
    }
  </div>
  <p class="mt-3 text-sm leading-relaxed text-(--color-ink-600) sm:text-base">
    {service.summary[lang]}
  </p>
  <ul class="mt-5 space-y-1.5">
    {
      service.highlights[lang].map((h) => (
        <li class="flex items-start gap-2 text-sm text-(--color-ink-700)">
          <span
            class="mt-1.5 inline-block h-1 w-1 shrink-0 rounded-full bg-(--color-brand-500)"
            aria-hidden="true"
          />
          <span>{h}</span>
        </li>
      ))
    }
  </ul>
  <p
    class="mt-6 text-sm font-semibold text-(--color-brand-600) group-hover:text-(--color-brand-700)"
  >
    {isExternal ? visitSite : learnMore} →
  </p>
</a>
