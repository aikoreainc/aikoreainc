---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { company, type Lang } from "../data/company";

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const {
  title,
  description = "한국인공지능 주식회사 — 신뢰가능 AI를 설계하는 연구 기반 회사",
  lang = "ko",
} = Astro.props;

const currentPath = Astro.url.pathname;
const altLang: Lang = lang === "ko" ? "en" : "ko";
const altPath = (() => {
  const stripped = currentPath.replace(/^\/en/, "") || "/";
  return altLang === "en"
    ? `/en${stripped === "/" ? "" : stripped}`
    : stripped;
})();

const siteOrigin = "https://aikoreainc.com";
const canonical = new URL(currentPath, siteOrigin).toString();
const altUrl = new URL(altPath, siteOrigin).toString();
const ogImage = new URL("/img/logo/wordmark-symbol-blue-ko-trimmed.png", siteOrigin).toString();

const GA_ID = "G-824905R5KV";
const isProd = import.meta.env.PROD;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: company.legalName[lang],
  url: siteOrigin,
  logo: ogImage,
  email: company.email,
  foundingDate: company.established,
  address: {
    "@type": "PostalAddress",
    streetAddress: company.address[lang]
  }
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/img/logo/symbol-blue.png" />
    <link rel="apple-touch-icon" href="/img/logo/symbol-blue.png" />
    <link rel="alternate" hreflang={altLang} href={altUrl} />
    <link rel="alternate" hreflang={lang} href={canonical} />
    <link rel="alternate" hreflang="x-default" href={siteOrigin + "/"} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang === "ko" ? "ko_KR" : "en_US"} />
    <meta property="og:locale:alternate" content={altLang === "ko" ? "ko_KR" : "en_US"} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="한국인공지능 AI Korea Inc." />
    <meta property="og:site_name" content="AI Korea Inc." />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    {
      isProd && (
        <>
          <script
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}
          />
          <script is:inline define:vars={{ GA_ID }}>
            {`
              window.dataLayer = window.dataLayer || [];
              function gtag(){dataLayer.push(arguments);}
              gtag('js', new Date());
              gtag('config', GA_ID, { anonymize_ip: true });
            `}
          </script>
        </>
      )
    }
    
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-(--color-brand-600) focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
    >
      {lang === "ko" ? "본문 바로가기" : "Skip to main content"}
    </a>
    <Header lang={lang} currentPath={currentPath} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
