---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { company } from "../data/company";
---

<BaseLayout
  title="문의 — 한국인공지능"
  description="신뢰가능 AI 컨설팅, 데이터·대시보드 협업, Homosilicus 문의 — aikoreainc@gmail.com으로 연락 주세요."
>
  <section class="container-page py-16 sm:py-24">
    <SectionHeading
      eyebrow="CONTACT"
      title="무엇이든 편하게 문의 주세요."
      description="AI 도입 · 환경 GIS 대시보드 · 데이터 공급 · 공동 연구 의뢰 모두 환영합니다. 1~2 영업일 안에 회신합니다."
    />

    <div class="mt-12 grid gap-8 sm:mt-16 md:grid-cols-[1.2fr_1fr]">
      <article
        class="rounded-2xl border border-(--color-ink-200) bg-white p-8 sm:p-10"
      >
        <p
          class="text-xs font-semibold uppercase tracking-wider text-(--color-brand-600)"
        >
          이메일
        </p>
        <h3 class="mt-3 text-2xl font-bold text-(--color-ink-900) sm:text-3xl">
          <a
            href={`mailto:${company.email}`}
            class="hover:text-(--color-brand-700)"
          >
            {company.email}
          </a>
        </h3>
        <p class="mt-4 text-sm leading-relaxed text-(--color-ink-600) sm:text-base">
          1~2 영업일 안에 회신합니다. 의뢰 범위·일정·예산이 미확정이라도
          괜찮습니다. 메일 제목에 <strong class="text-(--color-ink-900)"
            >[문의]</strong
          > 또는 사업 라인(예: <em class="not-italic">[Homosilicus 문의]</em>)을
          기입해 주시면 빠르게 분류해 드립니다.
        </p>
        <a
          href={`mailto:${company.email}`}
          class="mt-6 inline-block rounded-lg bg-(--color-brand-600) px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-(--color-brand-700)"
        >
          메일로 문의
        </a>
      </article>

      <article
        class="rounded-2xl border border-(--color-ink-200) bg-(--color-ink-50) p-8 sm:p-10"
      >
        <p
          class="text-xs font-semibold uppercase tracking-wider text-(--color-brand-600)"
        >
          회사정보
        </p>
        <dl
          class="mt-4 space-y-3 text-sm text-(--color-ink-700) [&_dt]:text-(--color-ink-500) [&_dt]:text-xs [&_dt]:uppercase [&_dt]:tracking-wider [&_dd]:mt-1"
        >
          <div>
            <dt>법인명</dt>
            <dd>{company.legalName.ko}</dd>
          </div>
          <div>
            <dt>대표</dt>
            <dd>{company.ceo.ko} · {company.ceoTitle.ko}</dd>
          </div>
          <div>
            <dt>사업자등록번호</dt>
            <dd>{company.bizRegNo}</dd>
          </div>
          <div>
            <dt>업태·업종</dt>
            <dd>{company.bizType.ko}</dd>
          </div>
          <div>
            <dt>주소</dt>
            <dd>{company.address.ko}</dd>
          </div>
          <div>
            <dt>이메일</dt>
            <dd>{company.email}</dd>
          </div>
        </dl>
      </article>
    </div>
  </section>
</BaseLayout>
