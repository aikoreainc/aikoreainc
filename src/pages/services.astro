---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ServiceCard from "../components/ServiceCard.astro";
import { services } from "../data/services";
---

<BaseLayout
  title="서비스 — 한국인공지능"
  description="환경·공공·산업의 의사결정을 신뢰가능 AI로 운영합니다. 채용공고 데이터, 환경 GIS 대시보드, 신뢰가능 AI 설계, Homosilicus SaaS — 4개 사업 라인."
>
  <section class="container-page py-16 sm:py-24">
    <SectionHeading
      eyebrow="SERVICES"
      title="환경·공공·산업의 의사결정을 신뢰가능 AI로 운영합니다."
      description="4개 사업 라인 · 7개 협력 기관 · SCIE 논문 2편 — HUFS 교원창업기업으로, 데이터·모델·대시보드·SaaS를 한 팀에서 풀스택으로 운영합니다."
    />

    <div class="mt-12 grid gap-6 sm:mt-16 md:grid-cols-2 md:items-stretch">
      {services.map((service) => <ServiceCard service={service} lang="ko" />)}
    </div>
  </section>
</BaseLayout>
