---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import PartnersStrip from "../../components/PartnersStrip.astro";
import { company } from "../../data/company";

const differentiators = [
  {
    title: "We run the methods we publish.",
    body: "Founded by Prof. Donghyun Lee of HUFS. Two SCIE papers in Journal of Cleaner Production (2024 and 2025) define the trustworthy-AI methods we ship.",
  },
  {
    title: "Data, models, dashboards, and SaaS — one team.",
    body: "Job-posting data (JobAI), environmental GIS dashboards (BirdFluAI · Air-Report), and our B2B SaaS (Homosilicus) — four product lines, all operated in-house.",
  },
  {
    title: "We design AI you can put into decisions.",
    body: "Explainable AI (XAI) and uncertainty quantification (UQ) at the core — built for public-, government-, and industry-sector decisions that require accountability.",
  },
];
---

<BaseLayout
  title="About — AIKoreaInc"
  description="AIKoreaInc is a HUFS faculty-founded company. We operate trustworthy-AI methods published in SCIE journals, validated together with government and research partners."
  lang="en"
>
  <section class="container-page py-16 sm:py-24">
    <SectionHeading
      eyebrow="ABOUT"
      title="Where research becomes product."
      description="AIKoreaInc is a HUFS faculty-founded company. Published methods from Journal of Cleaner Production (2024 · 2025) become operating dashboards and a B2B SaaS."
    />
  </section>

  <section class="container-page pb-16 sm:pb-24">
    <div
      class="grid gap-10 rounded-2xl border border-(--color-ink-200) bg-(--color-ink-50) p-8 sm:p-12 md:grid-cols-[1fr_1.5fr]"
    >
      <div>
        <p
          class="text-xs font-semibold uppercase tracking-wider text-(--color-brand-600)"
        >
          Founder
        </p>
        <h3 class="mt-2 text-2xl font-bold text-(--color-ink-900)">
          Donghyun Lee
        </h3>
        <p class="mt-1 text-sm text-(--color-ink-600)">
          CEO · Professor, HUFS
        </p>
        <a
          href={company.links.professor}
          target="_blank"
          rel="noopener"
          class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-(--color-brand-600) hover:text-(--color-brand-700)"
        >
          Faculty page
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-3.5 w-3.5"
            aria-hidden="true"
          >
            <path d="M7 17L17 7"></path>
            <polyline points="7 7 17 7 17 17"></polyline>
          </svg>
        </a>
      </div>
      <div class="text-sm leading-relaxed text-(--color-ink-700) sm:text-base">
        <p>
          His research focuses on <strong class="text-(--color-ink-900)"
            >reliable AI, explainable AI, environmental prediction, and
            public-health AI</strong
          >. He runs a research–industry bridge model at HUFS Division of
          Social Science &amp; AI.
        </p>
        <p class="mt-4">
          AIKoreaInc applies that research to job-posting data, environmental
          GIS dashboards, and trustworthy-AI consulting — and operates its own
          SaaS, <a
            href={company.links.homosilicus}
            target="_blank"
            rel="noopener"
            class="font-semibold text-(--color-brand-600) hover:text-(--color-brand-700)"
            >Homosilicus</a
          >.
        </p>
        <p class="mt-4">
          We collaborate with seven institutions: Korea Environment Institute
          (KEI), Samsung Medical Center (SMC), Korea Research Institute for
          Vocational Education and Training (KRIVET), Busan Institute of S&amp;T
          Evaluation and Planning (BISTEP), Korea Testing Laboratory (KTL),
          National Institute of Wildlife Disease Control (NIWDC), and Green Vet
          Inc.
        </p>
      </div>
    </div>
  </section>

  <section class="container-page pb-24 sm:pb-32">
    <SectionHeading eyebrow="WHY US" title="Three differences — research, full-stack, Trustworthy AI." />
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        differentiators.map((d, i) => (
          <div class="rounded-2xl border border-(--color-ink-200) bg-white p-7 sm:p-8">
            <p class="text-xs font-semibold tracking-wider text-(--color-brand-600)">
              0{i + 1}
            </p>
            <h3 class="mt-3 text-lg font-bold text-(--color-ink-900) sm:text-xl">
              {d.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-(--color-ink-600) sm:text-base">
              {d.body}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <PartnersStrip lang="en" />

  <section class="container-page py-16 sm:py-20">
    <div
      class="rounded-2xl border border-(--color-ink-200) bg-(--color-ink-50) px-8 py-10 sm:px-12 sm:py-12"
    >
      <p
        class="text-xs font-semibold uppercase tracking-wider text-(--color-brand-600)"
      >
        Next step
      </p>
      <h2 class="mt-3 text-2xl font-bold tracking-tight text-(--color-ink-900) sm:text-3xl">
        Explore our services, or contact us directly.
      </h2>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="/en/services/"
          class="rounded-lg bg-(--color-brand-600) px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-(--color-brand-700)"
        >
          View services
        </a>
        <a
          href="/en/contact/"
          class="rounded-lg border border-(--color-ink-200) bg-white px-5 py-2.5 text-sm font-semibold text-(--color-ink-900) transition hover:border-(--color-ink-400)"
        >
          Contact us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
