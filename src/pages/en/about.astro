---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import PartnersStrip from "../../components/PartnersStrip.astro";
import { company } from "../../data/company";
---

<BaseLayout
  title="About — AI Korea Inc."
  description="AI Korea Inc. is a HUFS faculty-founded company. We operate trustworthy-AI methods published in SCIE journals, validated together with government and research partners."
  lang="en"
>
  <section class="container-page py-16 sm:py-24">
    <SectionHeading
      eyebrow="ABOUT"
      title="Where research becomes product."
      description="AI Korea Inc. is a HUFS faculty-founded company. Published methods from Journal of Cleaner Production (2024 · 2025) become operating dashboards and a B2B SaaS."
    />
  </section>

  <section class="container-page pb-16 sm:pb-24">
    <div
      class="grid gap-10 rounded-2xl border border-(--color-ink-200) bg-(--color-ink-50) p-8 sm:gap-12 sm:p-12 md:grid-cols-[1fr_1.5fr] md:gap-16"
    >
      <div>
        <p
          class="text-xs font-semibold uppercase tracking-wider text-(--color-brand-600)"
        >
          Founder
        </p>
        <h3 class="mt-2 text-2xl font-bold text-(--color-ink-900)">
          Donghyun Lee
        </h3>
        <p class="mt-1 text-sm text-(--color-ink-600)">
          CEO · Professor, HUFS
        </p>
        <a
          href={company.links.professor}
          target="_blank"
          rel="noopener"
          class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-(--color-brand-600) hover:text-(--color-brand-700)"
        >
          Faculty page
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-3.5 w-3.5"
            aria-hidden="true"
          >
            <path d="M7 17L17 7"></path>
            <polyline points="7 7 17 7 17 17"></polyline>
          </svg>
        </a>
      </div>
      <div class="text-sm leading-relaxed text-(--color-ink-700) sm:text-base">
        <p>
          His research focuses on <strong class="text-(--color-ink-900)"
            >reliable AI, explainable AI, environmental prediction, and
            public-health AI</strong
          >. He runs a research–industry bridge model at HUFS Division of
          Social Science &amp; AI.
        </p>
        <p class="mt-4">
          AI Korea Inc. applies that research to job-posting data, environmental
          GIS dashboards, and trustworthy-AI consulting — and operates its own
          SaaS, <a
            href={company.links.homosilicus}
            target="_blank"
            rel="noopener"
            class="font-semibold text-(--color-brand-600) hover:text-(--color-brand-700)"
            >Homosilicus</a
          >.
        </p>
        <p class="mt-4">
          We collaborate with seven institutions: Korea Environment Institute
          (KEI), Samsung Medical Center (SMC), Korea Research Institute for
          Vocational Education and Training (KRIVET), Busan Institute of S&amp;T
          Evaluation and Planning (BISTEP), Korea Testing Laboratory (KTL),
          National Institute of Wildlife Disease Control (NIWDC), and Green Vet
          Inc.
        </p>
      </div>
    </div>
  </section>

  <PartnersStrip lang="en" />

  <section class="container-page py-16 sm:py-24">
    <div
      class="rounded-2xl border border-(--color-ink-200) bg-(--color-ink-50) px-8 py-10 sm:px-12 sm:py-12"
    >
      <p
        class="text-xs font-semibold uppercase tracking-[0.12em] text-(--color-brand-600)"
      >
        Next step
      </p>
      <h2 class="mt-3 text-2xl font-bold tracking-tight text-balance text-(--color-ink-900) sm:text-3xl">
        Explore our services, or contact us directly.
      </h2>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="/en/services/"
          class="inline-flex items-center justify-center rounded-lg bg-(--color-brand-600) px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition duration-200 hover:bg-(--color-brand-700) hover:shadow-md"
        >
          View services
        </a>
        <a
          href="/en/contact/"
          class="inline-flex items-center justify-center rounded-lg border border-(--color-ink-200) bg-white px-5 py-2.5 text-sm font-semibold text-(--color-ink-900) transition duration-200 hover:border-(--color-ink-400)"
        >
          Contact us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
