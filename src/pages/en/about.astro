---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { company } from "../../data/company";

const differentiators = [
  {
    title: "Research-grounded reliability",
    body: "Founded by Prof. Donghyun Lee of HUFS. Our trustworthy-AI methods are published in Journal of Cleaner Production (2024, 2025). We surface not only the answer but the reasoning behind it.",
  },
  {
    title: "Full-stack execution, data to SaaS",
    body: "Job-posting data pipelines, environmental GIS dashboards, and Homosilicus — our own SaaS. We do not stop at prototypes; we ship and operate.",
  },
  {
    title: "Trustworthy AI expertise",
    body: "Explainable AI and uncertainty quantification are at our core. Built for accountability-critical decisions in government, public sector, and enterprise.",
  },
];
---

<BaseLayout
  title="About — AIKoreaInc"
  description="AIKoreaInc is a HUFS faculty spin-off applying trustworthy-AI methods published in SCI journals to real industry and public-sector problems."
  lang="en"
>
  <section class="container-page py-16 sm:py-24">
    <SectionHeading
      eyebrow="ABOUT"
      title="Trustworthy AI, grounded in research"
      description="AIKoreaInc is a spin-off from Prof. Donghyun Lee's lab at Hankuk University of Foreign Studies (HUFS). We carry academic methodology into industry and the public sector, building AI that explains its own reasoning."
    />
  </section>

  <section class="container-page pb-16 sm:pb-24">
    <div
      class="grid gap-10 rounded-2xl border border-(--color-ink-200) bg-(--color-ink-50) p-8 sm:p-12 md:grid-cols-[1fr_1.5fr]"
    >
      <div>
        <p
          class="text-xs font-semibold uppercase tracking-wider text-(--color-brand-600)"
        >
          Founder
        </p>
        <h3 class="mt-2 text-2xl font-bold text-(--color-ink-900)">
          Donghyun Lee
        </h3>
        <p class="mt-1 text-sm text-(--color-ink-600)">
          CEO · Professor, HUFS
        </p>
        <a
          href={company.links.professor}
          target="_blank"
          rel="noopener"
          class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-(--color-brand-600) hover:text-(--color-brand-700)"
        >
          Faculty page
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-3.5 w-3.5"
            aria-hidden="true"
          >
            <path d="M7 17L17 7"></path>
            <polyline points="7 7 17 7 17 17"></polyline>
          </svg>
        </a>
      </div>
      <div class="text-sm leading-relaxed text-(--color-ink-700) sm:text-base">
        <p>
          His research focuses on <strong class="text-(--color-ink-900)"
            >reliable AI, explainable AI, environmental prediction, and
            public-health AI</strong
          >. He runs a research–industry bridge model at HUFS Division of
          Social Science &amp; AI.
        </p>
        <p class="mt-4">
          AIKoreaInc applies that research to job-posting data, environmental
          GIS dashboards, and trustworthy-AI consulting — and operates its own
          SaaS, <a
            href={company.links.homosilicus}
            target="_blank"
            rel="noopener"
            class="font-semibold text-(--color-brand-600) hover:text-(--color-brand-700)"
            >Homosilicus</a
          >.
        </p>
      </div>
    </div>
  </section>

  <section class="container-page pb-24 sm:pb-32">
    <SectionHeading eyebrow="WHY US" title="What makes us different" />
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        differentiators.map((d, i) => (
          <div class="rounded-2xl border border-(--color-ink-200) bg-white p-7 sm:p-8">
            <p class="text-xs font-semibold tracking-wider text-(--color-brand-600)">
              0{i + 1}
            </p>
            <h3 class="mt-3 text-lg font-bold text-(--color-ink-900) sm:text-xl">
              {d.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-(--color-ink-600) sm:text-base">
              {d.body}
            </p>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
