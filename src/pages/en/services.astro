---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import { services } from "../../data/services";
---

<BaseLayout
  title="Services — AI Korea Inc."
  description="Explainable AI, actually in production. Four product lines, seven institutional partners, two SCIE papers — operated by one team."
  lang="en"
>
  <section class="container-page py-16 sm:py-24">
    <SectionHeading
      eyebrow="SERVICES"
      title="Explainable AI, actually in production."
      description="Four product lines, seven institutional partners, two SCIE papers — a research-grounded AI company operated end-to-end by one team."
    />

    <div class="mt-12 grid gap-6 sm:mt-16 md:grid-cols-2 md:items-stretch">
      {services.map((service) => <ServiceCard service={service} lang="en" />)}
    </div>
  </section>
</BaseLayout>
