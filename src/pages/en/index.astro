---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="AIKoreaInc — Trustworthy AI, Built on Research"
  description="AIKoreaInc is a research-grounded company building trustworthy AI for the data problems that matter — environment, public sector, and enterprise."
  lang="en"
>
  <section class="container-page py-24 sm:py-32">
    <div class="max-w-3xl">
      <p
        class="text-sm font-medium uppercase tracking-wider text-(--color-brand-600)"
      >
        AIKoreaInc
      </p>
      <h1
        class="mt-4 text-4xl font-bold tracking-tight text-(--color-ink-900) sm:text-6xl"
      >
        Trustworthy AI,<br />
        <span class="gradient-text">built on research.</span>
      </h1>
      <p class="mt-8 text-lg leading-relaxed text-(--color-ink-600) sm:text-xl">
        Founded by a HUFS professor, AIKoreaInc solves data problems that matter
        — <strong class="text-(--color-ink-900)">
          environment, public sector, and enterprise</strong
        > — across data pipelines, models, dashboards, and SaaS.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/en/services/"
          class="rounded-lg bg-(--color-brand-600) px-6 py-3 text-sm font-semibold text-white transition hover:bg-(--color-brand-700)"
        >
          Our services
        </a>
        <a
          href="/en/contact/"
          class="rounded-lg border border-(--color-ink-200) px-6 py-3 text-sm font-semibold text-(--color-ink-900) transition hover:border-(--color-ink-400)"
        >
          Get in touch
        </a>
      </div>
    </div>

    <div
      class="mt-32 rounded-2xl border border-(--color-ink-200) bg-(--color-ink-50) px-6 py-8 sm:px-10"
    >
      <p
        class="text-xs font-semibold uppercase tracking-wider text-(--color-ink-500)"
      >
        Phase 1 in progress
      </p>
      <p class="mt-2 text-sm leading-relaxed text-(--color-ink-700)">
        Header and footer are now live. Next: four business lines (job posting
        data, environmental GIS dashboards, trustworthy AI design, Homosilicus),
        case studies, and the research section.
      </p>
    </div>
  </section>
</BaseLayout>
