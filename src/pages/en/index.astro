---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import ResearchCard from "../../components/ResearchCard.astro";
import BusinessLinesDiagram from "../../components/BusinessLinesDiagram.astro";
import PartnersStrip from "../../components/PartnersStrip.astro";
import { services } from "../../data/services";
import { papers } from "../../data/research";
import { getCollection } from "astro:content";

const recentNews = (await getCollection("newsEn"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const differentiators = [
  {
    title: "We run the methods we publish.",
    body: "A HUFS faculty-founded company — the trustworthy-AI methods in J. Cleaner Production 2024 and 2025 are the same methods we ship.",
  },
  {
    title: "Data, models, dashboards, and SaaS — one team.",
    body: "JobAI, BirdFluAI, Air-Report, and Homosilicus — four product lines operated in-house. No vendor chains to orchestrate.",
  },
  {
    title: "We design AI you can put into decisions.",
    body: "Explainable AI (XAI) and uncertainty quantification (UQ), built for public-, government-, and industry-sector decisions that require accountability.",
  },
];

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<BaseLayout
  title="AIKoreaInc — Trustworthy AI, Built on Research"
  description="AIKoreaInc is a HUFS faculty-founded company that operates published trustworthy-AI methods end-to-end — data, models, dashboards, and SaaS — for environmental, public, and industry decisions."
  lang="en"
>
  <!-- Hero -->
  <section class="container-page py-24 sm:py-32">
    <div class="max-w-3xl">
      <p
        class="text-sm font-medium uppercase tracking-wider text-(--color-brand-600)"
      >
        AIKoreaInc
      </p>
      <h1
        class="mt-4 text-4xl font-bold tracking-tight text-(--color-ink-900) sm:text-6xl"
      >
        Trustworthy AI,<br />
        <span class="gradient-text">built on research.</span>
      </h1>
      <p class="mt-8 text-lg leading-relaxed text-(--color-ink-600) sm:text-xl">
        Designed and operated by a HUFS faculty-founded company — end-to-end
        across <strong class="text-(--color-ink-900)"
          >data, models, dashboards, and SaaS</strong
        >.<br />
        Built for environmental, public, and industrial decisions that require accountability.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/en/services/"
          class="rounded-lg bg-(--color-brand-600) px-6 py-3 text-sm font-semibold text-white transition hover:bg-(--color-brand-700)"
        >
          View services
        </a>
        <a
          href="/en/contact/"
          class="rounded-lg border border-(--color-ink-200) px-6 py-3 text-sm font-semibold text-(--color-ink-900) transition hover:border-(--color-ink-400)"
        >
          Contact us
        </a>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="border-y border-(--color-ink-200) bg-(--color-ink-50)">
    <div class="container-page py-8">
      <ul
        class="flex flex-wrap items-center justify-between gap-x-8 gap-y-3 text-sm text-(--color-ink-600)"
      >
        <li>
          <span class="font-semibold text-(--color-ink-900)">HUFS</span> faculty-founded
        </li>
        <li>
          <span class="font-semibold text-(--color-ink-900)">2 SCIE</span> papers
        </li>
        <li>
          <span class="font-semibold text-(--color-ink-900)">7</span> institutional
          partners
        </li>
        <li>
          <span class="font-semibold text-(--color-ink-900)">End-to-end</span> stack
        </li>
      </ul>
    </div>
  </section>

  <!-- Recent news -->
  <section class="container-page py-20 sm:py-24">
    <div class="flex items-end justify-between gap-6">
      <SectionHeading eyebrow="RECENT" title="Latest" />
      <a
        href="/en/news/"
        class="hidden shrink-0 text-sm font-semibold text-(--color-brand-600) hover:text-(--color-brand-700) sm:inline"
        >All news →</a
      >
    </div>
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {
        recentNews.map((entry) => (
          <article class="rounded-2xl border border-(--color-ink-200) bg-white p-6 transition hover:border-(--color-brand-400)">
            <time
              datetime={entry.data.date.toISOString().slice(0, 10)}
              class="text-xs font-semibold uppercase tracking-wider text-(--color-ink-500)"
            >
              {formatDate(entry.data.date)}
            </time>
            <h3 class="mt-3 text-base font-bold leading-snug text-(--color-ink-900)">
              {entry.data.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-(--color-ink-600)">
              {entry.data.summary}
            </p>
          </article>
        ))
      }
    </div>
    <a
      href="/en/news/"
      class="mt-6 inline-block text-sm font-semibold text-(--color-brand-600) hover:text-(--color-brand-700) sm:hidden"
      >All news →</a
    >
  </section>

  <!-- Business lines diagram + services -->
  <section class="container-page pb-24 sm:pb-32">
    <SectionHeading
      eyebrow="SERVICES"
      title="Trustworthy AI for environmental, public, and industrial decisions."
      description="Job-posting data, environmental GIS dashboards, trustworthy-AI design, and Homosilicus SaaS — data, models, dashboards, and SaaS, operated end-to-end by one team."
    />
    <div class="mt-12 sm:mt-16">
      <BusinessLinesDiagram lang="en" />
    </div>
    <div class="mt-16 grid gap-6 md:grid-cols-2">
      {services.map((service) => <ServiceCard service={service} lang="en" />)}
    </div>
  </section>

  <!-- Partners -->
  <PartnersStrip lang="en" />

  <!-- Why us -->
  <section class="bg-(--color-ink-900) text-white">
    <div class="container-page py-24 sm:py-32">
      <p
        class="text-xs font-semibold uppercase tracking-wider text-(--color-brand-400)"
      >
        WHY US
      </p>
      <h2 class="mt-3 max-w-2xl text-3xl font-bold tracking-tight sm:text-4xl">
        Three differences — research, full-stack, Trustworthy AI.
      </h2>
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {
          differentiators.map((d, i) => (
            <div>
              <p class="text-xs font-semibold tracking-wider text-(--color-brand-400)">
                0{i + 1}
              </p>
              <h3 class="mt-3 text-lg font-bold sm:text-xl">{d.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-(--color-ink-300) sm:text-base">
                {d.body}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Research preview -->
  <section class="container-page py-24 sm:py-32">
    <SectionHeading
      eyebrow="RESEARCH"
      title="The methods we publish are the methods we ship."
      description="Two SCIE papers in J. Cleaner Production, authored under AIKoreaInc affiliation — the same methods power our consulting, dashboards, and SaaS."
    />
    <div class="mt-12 grid gap-6">
      {papers.map((paper) => <ResearchCard paper={paper} lang="en" />)}
    </div>
    <div class="mt-10">
      <a
        href="/en/research/"
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-(--color-brand-600) hover:text-(--color-brand-700)"
      >
        See all research →
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="container-page pb-24 sm:pb-32">
    <div
      class="rounded-3xl bg-(--color-brand-600) px-8 py-14 text-white sm:px-14 sm:py-20"
    >
      <h2 class="max-w-2xl text-3xl font-bold tracking-tight sm:text-4xl">
        We operate the full AI stack — data, models, and dashboards — as one team. Scope can be defined together.
      </h2>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-(--color-brand-50) sm:text-lg">
        Scope, timing, and budget can be defined together. We reply within 1–2
        business days.
      </p>
      <a
        href="/en/contact/"
        class="mt-8 inline-block rounded-lg bg-white px-6 py-3 text-sm font-semibold text-(--color-brand-700) transition hover:bg-(--color-brand-50)"
      >
        Get in touch
      </a>
    </div>
  </section>
</BaseLayout>
