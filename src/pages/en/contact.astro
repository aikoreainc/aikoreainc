---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { company } from "../../data/company";
---

<BaseLayout
  title="Contact — AIKoreaInc"
  description="Reach out about trustworthy-AI consulting, data and dashboard collaboration, or Homosilicus — aikoreainc@gmail.com"
  lang="en"
>
  <section class="container-page py-16 sm:py-24">
    <SectionHeading
      eyebrow="CONTACT"
      title="Please reach out."
      description="AI adoption, environmental GIS dashboards, data delivery, or joint research — all welcome. We reply within 1–2 business days."
    />

    <div class="mt-12 grid gap-8 sm:mt-16 md:grid-cols-[1.2fr_1fr]">
      <article
        class="rounded-2xl border border-(--color-ink-200) bg-white p-8 sm:p-10"
      >
        <p
          class="text-xs font-semibold uppercase tracking-wider text-(--color-brand-600)"
        >
          Email
        </p>
        <h3 class="mt-3 text-2xl font-bold text-(--color-ink-900) sm:text-3xl">
          <a
            href={`mailto:${company.email}`}
            class="hover:text-(--color-brand-700)"
          >
            {company.email}
          </a>
        </h3>
        <p class="mt-4 text-sm leading-relaxed text-(--color-ink-600) sm:text-base">
          We reply within 1–2 business days. Scope, timing, and budget can be
          defined together. Adding a tag such as
          <strong class="text-(--color-ink-900)">[Inquiry]</strong>
          or the business line (e.g. <em class="not-italic">[Homosilicus]</em>)
          to the subject helps us route it quickly.
        </p>
        <a
          href={`mailto:${company.email}`}
          class="mt-6 inline-block rounded-lg bg-(--color-brand-600) px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-(--color-brand-700)"
        >
          Get in touch
        </a>
      </article>

      <article
        class="rounded-2xl border border-(--color-ink-200) bg-(--color-ink-50) p-8 sm:p-10"
      >
        <p
          class="text-xs font-semibold uppercase tracking-wider text-(--color-brand-600)"
        >
          Company
        </p>
        <dl
          class="mt-4 space-y-3 text-sm text-(--color-ink-700) [&_dt]:text-(--color-ink-500) [&_dt]:text-xs [&_dt]:uppercase [&_dt]:tracking-wider [&_dd]:mt-1"
        >
          <div>
            <dt>Legal Name</dt>
            <dd>{company.legalName.en}</dd>
          </div>
          <div>
            <dt>CEO</dt>
            <dd>{company.ceo.en} · {company.ceoTitle.en}</dd>
          </div>
          <div>
            <dt>Business Reg. No.</dt>
            <dd>{company.bizRegNo}</dd>
          </div>
          <div>
            <dt>Industry</dt>
            <dd>{company.bizType.en}</dd>
          </div>
          <div>
            <dt>Address</dt>
            <dd>{company.address.en}</dd>
          </div>
          <div>
            <dt>Email</dt>
            <dd>{company.email}</dd>
          </div>
        </dl>
      </article>
    </div>
  </section>
</BaseLayout>
