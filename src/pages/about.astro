---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import PartnersStrip from "../components/PartnersStrip.astro";
import { company } from "../data/company";
---

<BaseLayout
  title="회사소개 — 한국인공지능"
  description="한국인공지능 주식회사는 HUFS 이동현 교수 교원창업기업입니다. SCIE 학술지에 발표한 신뢰가능 AI 방법론을 정부·연구기관과 함께 검증하며 운영합니다."
>
  <section class="container-page py-16 sm:py-24">
    <SectionHeading
      eyebrow="ABOUT"
      title="연구가 그대로 제품이 되는 회사."
      description="한국인공지능 주식회사는 한국외국어대학교(HUFS) 이동현 교수 교원창업기업입니다. 연구 기반의 신뢰가능 AI를, 정부·연구기관과 함께 검증하며 운영합니다."
    />
  </section>

  <section class="container-page pb-16 sm:pb-24">
    <div
      class="grid gap-10 rounded-2xl border border-(--color-ink-200) bg-(--color-ink-50) p-8 sm:gap-12 sm:p-12 md:grid-cols-[1fr_1.5fr] md:gap-16"
    >
      <div>
        <p
          class="text-xs font-semibold uppercase tracking-wider text-(--color-brand-600)"
        >
          대표
        </p>
        <h3 class="mt-2 text-2xl font-bold text-(--color-ink-900)">
          이동현
        </h3>
        <p class="mt-1 text-sm text-(--color-ink-600)">
          대표이사 · 한국외국어대학교 교수
        </p>
        <a
          href={company.links.professor}
          target="_blank"
          rel="noopener"
          class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-(--color-brand-600) hover:text-(--color-brand-700)"
        >
          교수 홈페이지
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-3.5 w-3.5"
            aria-hidden="true"
          >
            <path d="M7 17L17 7"></path>
            <polyline points="7 7 17 7 17 17"></polyline>
          </svg>
        </a>
      </div>
      <div class="text-sm leading-relaxed text-(--color-ink-700) sm:text-base">
        <p>
          연구 분야는 <strong class="text-(--color-ink-900)">신뢰성 AI ·
            설명가능 AI · 환경 예측 · 공중보건 AI</strong>입니다. 한국외국어대학교
          Division of Social Science &amp; AI 소속으로, 학계와 산업을 잇는
          연구·창업 모델을 운영합니다.
        </p>
        <p class="mt-4">
          한국인공지능 주식회사는 이 연구를 토대로 채용 데이터·환경 GIS 대시보드·신뢰가능
          AI 컨설팅, 그리고 자체 SaaS 제품 <a
            href={company.links.homosilicus}
            target="_blank"
            rel="noopener"
            class="font-semibold text-(--color-brand-600) hover:text-(--color-brand-700)"
            >Homosilicus</a
          >를 운영합니다.
        </p>
        <p class="mt-4">
          한국환경연구원(KEI) · 삼성서울병원(SMC) · 한국직업능력연구원(KRIVET) ·
          부산산업과학혁신원(BISTEP) · 한국산업기술시험원(KTL) ·
          국립야생동물질병관리원(NIWDC) · (주)그린벳 등 7개 기관과
          협력합니다.
        </p>
      </div>
    </div>
  </section>

  <PartnersStrip lang="ko" />

  <section class="container-page py-16 sm:py-24">
    <div
      class="rounded-2xl border border-(--color-ink-200) bg-(--color-ink-50) px-8 py-10 sm:px-12 sm:py-12"
    >
      <p
        class="text-xs font-semibold uppercase tracking-[0.12em] text-(--color-brand-600)"
      >
        다음 단계
      </p>
      <h2 class="mt-3 text-2xl font-bold tracking-tight text-balance text-(--color-ink-900) sm:text-3xl">
        사업 라인을 확인하거나, 바로 문의하세요.
      </h2>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="/services/"
          class="inline-flex items-center justify-center rounded-lg bg-(--color-brand-600) px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition duration-200 hover:bg-(--color-brand-700) hover:shadow-md"
        >
          서비스 보기
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center justify-center rounded-lg border border-(--color-ink-200) bg-white px-5 py-2.5 text-sm font-semibold text-(--color-ink-900) transition duration-200 hover:border-(--color-ink-400)"
        >
          문의하기
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
