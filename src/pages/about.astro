---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { company } from "../data/company";

const differentiators = [
  {
    title: "연구 기반 신뢰성",
    body: "HUFS 이동현 교수 교원창업기업. SCI급 학술지 Journal of Cleaner Production에 신뢰가능 AI 방법론을 게재(2024·2025). 결과뿐 아니라 \"왜 그렇게 판단했는지\"까지 제시합니다.",
  },
  {
    title: "데이터부터 SaaS까지, 풀스택 실행",
    body: "채용공고 데이터(수집·DB), 환경 GIS 대시보드(시각화·운영), Homosilicus(SaaS 제품). 프로토타입에서 멈추지 않고 운영 단계까지 직접 만듭니다.",
  },
  {
    title: "신뢰가능 AI(Trustworthy AI) 전문성",
    body: "설명가능 AI(XAI)·불확실성 정량화가 핵심 기술. 정부·공공기관·기업의 의사결정처럼 \"근거가 필요한\" 영역에서 강점을 가집니다.",
  },
];
---

<BaseLayout
  title="회사소개 — 한국인공지능"
  description="한국인공지능(주)은 HUFS 이동현 교수 교원창업기업으로, 신뢰가능 AI 방법론을 학술지에 발표하고 실제 산업·공공 문제에 적용합니다."
>
  <section class="container-page py-16 sm:py-24">
    <SectionHeading
      eyebrow="ABOUT"
      title="연구 기반의 신뢰가능 AI 회사"
      description="한국인공지능(주)은 한국외국어대학교(HUFS) 이동현 교수 교원창업기업입니다. 학계의 방법론을 산업·공공 현장에 직접 적용해, 결과와 함께 근거를 제시하는 AI를 만듭니다."
    />
  </section>

  <section class="container-page pb-16 sm:pb-24">
    <div
      class="grid gap-10 rounded-2xl border border-(--color-ink-200) bg-(--color-ink-50) p-8 sm:p-12 md:grid-cols-[1fr_1.5fr]"
    >
      <div>
        <p
          class="text-xs font-semibold uppercase tracking-wider text-(--color-brand-600)"
        >
          대표
        </p>
        <h3 class="mt-2 text-2xl font-bold text-(--color-ink-900)">
          이동현
        </h3>
        <p class="mt-1 text-sm text-(--color-ink-600)">
          대표이사 · 한국외국어대학교 교수
        </p>
        <a
          href={company.links.professor}
          target="_blank"
          rel="noopener"
          class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-(--color-brand-600) hover:text-(--color-brand-700)"
        >
          교수 홈페이지
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-3.5 w-3.5"
            aria-hidden="true"
          >
            <path d="M7 17L17 7"></path>
            <polyline points="7 7 17 7 17 17"></polyline>
          </svg>
        </a>
      </div>
      <div class="text-sm leading-relaxed text-(--color-ink-700) sm:text-base">
        <p>
          연구 분야는 <strong class="text-(--color-ink-900)">신뢰성 AI ·
            설명가능 AI · 환경 예측 · 공중보건 AI</strong>입니다. 한국외국어대학교
          Division of Social Science &amp; AI 소속으로, 학계와 산업을 잇는
          연구·창업 모델을 운영합니다.
        </p>
        <p class="mt-4">
          AIKoreaInc는 이 연구를 토대로 채용 데이터·환경 GIS 대시보드·신뢰가능
          AI 컨설팅, 그리고 자체 SaaS 제품 <a
            href={company.links.homosilicus}
            target="_blank"
            rel="noopener"
            class="font-semibold text-(--color-brand-600) hover:text-(--color-brand-700)"
            >Homosilicus</a
          >를 운영합니다.
        </p>
      </div>
    </div>
  </section>

  <section class="container-page pb-24 sm:pb-32">
    <SectionHeading
      eyebrow="WHY US"
      title="다른 AI 회사와 무엇이 다른가"
    />
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        differentiators.map((d, i) => (
          <div class="rounded-2xl border border-(--color-ink-200) bg-white p-7 sm:p-8">
            <p class="text-xs font-semibold tracking-wider text-(--color-brand-600)">
              0{i + 1}
            </p>
            <h3 class="mt-3 text-lg font-bold text-(--color-ink-900) sm:text-xl">
              {d.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-(--color-ink-600) sm:text-base">
              {d.body}
            </p>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
