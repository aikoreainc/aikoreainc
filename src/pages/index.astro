---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ResearchCard from "../components/ResearchCard.astro";
import BusinessLinesDiagram from "../components/BusinessLinesDiagram.astro";
import PartnersStrip from "../components/PartnersStrip.astro";
import { services } from "../data/services";
import { papers } from "../data/research";
import { getCollection } from "astro:content";

const recentNews = (await getCollection("newsKo"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const differentiators = [
  {
    title: "학술지 게재 방법론을 그대로 운영합니다.",
    body: "HUFS 교원창업기업으로, J. Cleaner Production 2024·2025에 발표한 신뢰가능 AI 방법론을 사업에 그대로 적용합니다.",
  },
  {
    title: "데이터·모델·대시보드·SaaS를 직접 운영합니다.",
    body: "JobAI, BirdFluAI, Air-Report, Homosilicus — 4개 라인을 한 팀 안에서 운영합니다. 외부 벤더를 조율할 필요가 없습니다.",
  },
  {
    title: "결정에 쓸 수 있는 AI를 설계합니다.",
    body: "설명가능 AI(XAI)와 불확실성 정량화(UQ)로, 의사결정 책임이 따르는 정부·공공·산업 영역에 맞춰 모델·평가·보고 체계를 설계합니다.",
  },
];

const formatDate = (d: Date) =>
  d.toLocaleDateString("ko-KR", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<BaseLayout
  title="한국인공지능 — 신뢰가능 AI 연구 기반 회사"
  description="한국인공지능 주식회사는 SCIE 학술지에 발표한 신뢰가능 AI 방법론을, 데이터·모델·대시보드·SaaS로 한 팀에서 운영하는 HUFS 교원창업 연구 기반 회사입니다."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="glow-hero pointer-events-none absolute inset-x-0 top-0 -z-10"
      aria-hidden="true"
    ></div>
    <div class="container-page pt-24 pb-16 sm:pt-32 sm:pb-24">
      <div class="max-w-3xl">
        <p
          class="text-xs font-semibold uppercase tracking-[0.14em] text-(--color-brand-600)"
        >
          AI Korea Inc.
        </p>
        <h1
          class="mt-5 text-4xl font-bold leading-[1.1] tracking-tight text-balance text-(--color-ink-900) sm:text-6xl sm:leading-[1.05]"
        >
          신뢰가능 AI를<br />
          <span class="gradient-text">설계하고 운영합니다.</span>
        </h1>
        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-(--color-ink-600) sm:text-xl">
          SCIE 학술지에 발표한 방법론을, <strong class="text-(--color-ink-900)"
            >데이터·모델·대시보드·SaaS</strong
          >로 한 팀에서 운영합니다.<br />
          HUFS 교원창업 연구 기반 회사 — 환경·공공·산업의 의사결정 영역에 적용합니다.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a
            href="/services/"
            class="inline-flex items-center justify-center rounded-lg bg-(--color-brand-600) px-6 py-3 text-sm font-semibold text-white shadow-sm transition duration-200 hover:bg-(--color-brand-700) hover:shadow-md"
          >
            서비스 보기
          </a>
          <a
            href="/contact/"
            class="inline-flex items-center justify-center rounded-lg border border-(--color-ink-200) bg-white px-6 py-3 text-sm font-semibold text-(--color-ink-900) transition duration-200 hover:border-(--color-ink-400) hover:bg-(--color-ink-50)"
          >
            문의하기
          </a>
        </div>
      </div>
      
      <div class="mt-16 sm:mt-24 relative max-w-5xl mx-auto">
        <div class="relative w-full overflow-hidden rounded-2xl shadow-2xl ring-1 ring-(--color-ink-200)">
          <img src="/img/hero-dashboard-mockup.png" alt="환경 GIS 대시보드 화면" class="w-full h-auto object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="border-y border-(--color-ink-200) bg-(--color-ink-50)">
    <div class="container-page py-6 sm:py-8">
      <ul
        class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm text-(--color-ink-600) sm:grid-cols-4 sm:divide-x sm:divide-(--color-ink-200)"
      >
        <li class="sm:px-6 sm:first:pl-0">
          <span class="font-semibold text-(--color-ink-900)">HUFS</span> 교원창업
        </li>
        <li class="sm:px-6">
          <span class="font-semibold text-(--color-ink-900)">SCIE 논문</span> 2편
        </li>
        <li class="sm:px-6">
          <span class="font-semibold text-(--color-ink-900)">협력기관</span> 7곳
        </li>
        <li class="sm:px-6 sm:last:pr-0">
          <span class="font-semibold text-(--color-ink-900)">풀스택</span> 운영
        </li>
      </ul>
    </div>
  </section>

  <!-- Recent news -->
  <section class="container-page py-16 sm:py-24">
    <div class="flex items-end justify-between gap-6">
      <SectionHeading eyebrow="RECENT" title="최근 소식" />
      <a
        href="/news/"
        class="hidden shrink-0 text-sm font-semibold text-(--color-brand-600) transition-colors hover:text-(--color-brand-700) sm:inline"
        >전체 소식 →</a
      >
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        recentNews.map((entry) => (
          <article class="lift-on-hover flex flex-col rounded-2xl border border-(--color-ink-200) bg-white p-6 hover:-translate-y-0.5 hover:border-(--color-brand-400)">
            <time
              datetime={entry.data.date.toISOString().slice(0, 10)}
              class="text-xs font-semibold uppercase tracking-[0.1em] text-(--color-ink-500)"
            >
              {formatDate(entry.data.date)}
            </time>
            <h3 class="mt-3 text-lg font-bold leading-snug text-(--color-ink-900)">
              {entry.data.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-(--color-ink-600)">
              {entry.data.summary}
            </p>
          </article>
        ))
      }
    </div>
    <a
      href="/news/"
      class="mt-8 inline-block text-sm font-semibold text-(--color-brand-600) hover:text-(--color-brand-700) sm:hidden"
      >전체 소식 →</a
    >
  </section>

  <!-- Business lines diagram + services -->
  <section class="container-page pb-16 sm:pb-24">
    <SectionHeading
      eyebrow="SERVICES"
      title="환경·공공·산업의 의사결정을 신뢰가능 AI로 운영합니다."
      description="채용공고 데이터 · 환경 GIS 대시보드 · 신뢰가능 AI 설계 · Homosilicus SaaS — 데이터·모델·대시보드·SaaS를 한 팀에서 풀스택으로 운영합니다."
    />
    <div class="mt-12 sm:mt-16">
      <BusinessLinesDiagram lang="ko" />
    </div>
    <div class="mt-16 grid gap-6 md:grid-cols-2 md:items-stretch">
      {services.map((service) => <ServiceCard service={service} lang="ko" />)}
    </div>
  </section>

  <!-- Partners -->
  <PartnersStrip lang="ko" />

  <!-- Why us -->
  <section class="relative overflow-hidden bg-(--color-ink-900) text-white">
    <div
      class="glow-dark pointer-events-none absolute inset-0 -z-0"
      aria-hidden="true"
    ></div>
    <div class="container-page relative py-24 sm:py-32">
      <p
        class="text-xs font-semibold uppercase tracking-[0.14em] text-(--color-brand-400)"
      >
        WHY US
      </p>
      <h2 class="mt-3 max-w-2xl text-3xl font-bold leading-[1.15] tracking-tight text-balance sm:text-4xl">
        세 가지 차별 — 연구·풀스택·Trustworthy AI.
      </h2>
      <div class="mt-14 grid gap-8 md:grid-cols-3 md:gap-10">
        {
          differentiators.map((d, i) => (
            <div class="relative">
              <p class="font-mono text-sm font-semibold tracking-[0.08em] text-(--color-brand-400)">
                0{i + 1}
              </p>
              <h3 class="mt-3 text-lg font-bold leading-snug text-white sm:text-xl">{d.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-(--color-ink-200) sm:text-base">
                {d.body}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Research preview -->
  <section class="container-page py-24 sm:py-32">
    <SectionHeading
      eyebrow="RESEARCH"
      title="학술지 게재 방법론을 그대로 운영합니다."
      description="한국인공지능 소속으로 J. Cleaner Production에 발표한 SCIE 논문 2편 — 같은 방법론이 컨설팅·대시보드·SaaS에 적용됩니다."
    />
    <div class="mt-12 grid gap-6 md:grid-cols-2 md:items-stretch">
      {papers.map((paper) => <ResearchCard paper={paper} lang="ko" />)}
    </div>
    <div class="mt-10">
      <a
        href="/research/"
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-(--color-brand-600) transition-colors hover:text-(--color-brand-700)"
      >
        모든 연구실적 보기 →
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="container-page pb-24 sm:pb-32">
    <div
      class="relative overflow-hidden rounded-3xl bg-(--color-brand-600) px-8 py-14 text-white sm:px-14 sm:py-20"
    >
      <div
        class="glow-cta pointer-events-none absolute inset-0"
        aria-hidden="true"
      ></div>
      <div class="relative">
        <h2 class="max-w-3xl text-3xl font-bold leading-[1.15] tracking-tight text-balance sm:text-4xl">
          AI 도입의 데이터·모델·대시보드를 한 팀에서 운영합니다. 의뢰 범위는 함께 정하면 됩니다.
        </h2>
        <p class="mt-5 max-w-2xl text-base leading-relaxed text-(--color-brand-50) sm:text-lg">
          의뢰 범위·일정·예산은 함께 정하면 됩니다. 1~2 영업일 안에 회신합니다.
        </p>
        <a
          href="/contact/"
          class="mt-8 inline-flex items-center justify-center rounded-lg bg-white px-6 py-3 text-sm font-semibold text-(--color-brand-700) shadow-sm transition duration-200 hover:bg-(--color-brand-50) hover:shadow-md"
        >
          문의하기
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
