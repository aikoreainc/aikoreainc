---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ResearchCard from "../components/ResearchCard.astro";
import { papers } from "../data/research";
---

<BaseLayout
  title="연구실적 — 한국인공지능"
  description="한국인공지능 소속으로 J. Cleaner Production에 발표한 SCIE 논문 2편 — 신뢰가능 AI · 설명가능 AI(XAI) · 불확실성 정량화(UQ) 방법론."
>
  <section class="container-page py-16 sm:py-24">
    <SectionHeading
      eyebrow="RESEARCH"
      title="학술지 게재 방법론을 그대로 운영합니다."
      description="한국인공지능 소속으로 Journal of Cleaner Production에 발표한 SCIE 논문 2편입니다. 같은 방법론이 컨설팅·대시보드·SaaS에 적용됩니다."
    />

    <div class="mt-12 grid gap-6 sm:mt-16">
      {papers.map((paper) => <ResearchCard paper={paper} lang="ko" />)}
    </div>
  </section>

  <section class="container-page pb-24 sm:pb-32">
    <div
      class="rounded-2xl border border-(--color-ink-200) bg-(--color-ink-50) px-8 py-10 sm:px-12 sm:py-12"
    >
      <p
        class="text-xs font-semibold uppercase tracking-wider text-(--color-brand-600)"
      >
        다음 단계
      </p>
      <h2 class="mt-3 text-2xl font-bold tracking-tight text-(--color-ink-900) sm:text-3xl">
        같은 방법론을 도입하고 싶으신가요?
      </h2>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-(--color-ink-600) sm:text-base">
        XAI · 불확실성 정량화 기반 신뢰가능 AI 설계를 의뢰 형태로 제공하고 있습니다. 1~2 영업일 안에 회신합니다.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="/services/"
          class="rounded-lg bg-(--color-brand-600) px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-(--color-brand-700)"
        >
          서비스 보기
        </a>
        <a
          href="/contact/"
          class="rounded-lg border border-(--color-ink-200) bg-white px-5 py-2.5 text-sm font-semibold text-(--color-ink-900) transition hover:border-(--color-ink-400)"
        >
          신뢰가능 AI 설계 문의
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
