---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="페이지를 찾을 수 없습니다 — 한국인공지능"
  description="요청하신 페이지를 찾을 수 없습니다. 메인으로 돌아가시거나 문의 주세요."
>
  <section class="container-page py-32 sm:py-40">
    <div class="max-w-2xl">
      <p
        class="text-xs font-semibold uppercase tracking-wider text-(--color-brand-600)"
      >
        404
      </p>
      <h1
        class="mt-4 text-4xl font-bold tracking-tight text-(--color-ink-900) sm:text-5xl"
      >
        페이지를 찾을 수 없습니다.
      </h1>
      <p class="mt-6 text-base leading-relaxed text-(--color-ink-600) sm:text-lg">
        주소가 변경되었거나, 더 이상 운영하지 않는 페이지일 수 있습니다.<br />
        This page can't be found. The URL may have changed or the page is no
        longer in use.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/"
          class="rounded-lg bg-(--color-brand-600) px-6 py-3 text-sm font-semibold text-white transition hover:bg-(--color-brand-700)"
        >
          홈으로 · Home
        </a>
        <a
          href="/services/"
          class="rounded-lg border border-(--color-ink-200) px-6 py-3 text-sm font-semibold text-(--color-ink-900) transition hover:border-(--color-ink-400)"
        >
          서비스 보기 · View services
        </a>
        <a
          href="/en/"
          class="rounded-lg border border-(--color-ink-200) px-6 py-3 text-sm font-semibold text-(--color-ink-700) transition hover:border-(--color-ink-400)"
        >
          English
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
